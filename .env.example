# DeepSeek — agente universal único de IA (DNA na Web, Voz do Lojista,
# Mapeador Universal, Raspador) — gerar em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Gemini — usado SOMENTE para embeddings da Busca Vetorial (gemini-embedding-001),
# não é mais usado para geração de texto/IA — gerar em https://aistudio.google.com/api-keys
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001

# Busca web (colonização de imagens, DNA na Web)
SERPER_API_KEY=
GOOGLE_SEARCH_KEY=
GOOGLE_SEARCH_CX=

# Bling (ERP)
BLING_API_KEY=
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Wix
WIX_API_KEY=
WIX_SITE_ID=

# Google Drive (conta de serviço)
GOOGLE_SERVICE_ACCOUNT_JSON=

# MCP
MCP_AUTH_TOKEN=

# Auto-enrich (job 24/7)
AUTO_ENRICH_ENABLED=true
AUTO_ENRICH_INTERVAL_MIN=
AUTO_ENRICH_BATCH_SIZE=
AUTO_ENRICH_DNA_COOLDOWN_H=
AUTO_ENRICH_IMG_COOLDOWN_H=

# Outros
PORT=
DB_PATH=
RENDER_EXTERNAL_URL=
