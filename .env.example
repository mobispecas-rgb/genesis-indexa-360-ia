# Genesis Indexa 360 IA — Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrao: 10000)
PORT=10000

# Ambiente: development | production
NODE_ENV=development

# API Key da Anthropic (Claude Haiku) — OBRIGATORIO para IA
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# URL publica da aplicacao (usado para keep-alive em producao)
# Exemplo: https://genesis-indexa-360-ia.onrender.com
APP_URL=http://localhost:10000
