# Gemini (DNA na Web + Busca Vetorial) — gerar em https://aistudio.google.com/api-keys
GEMINI_API_KEY=
EMBEDDING_MODEL=text-embedding-004

# DeepSeek (fallback de custo do DNA na Web, entre Gemini e Claude) — gerar em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic (Claude) — agentes/MCP do Genesis
ANTHROPIC_API_KEY=

# Busca web (colonização de imagens, DNA na Web)
SERPER_API_KEY=
GOOGLE_SEARCH_KEY=
GOOGLE_SEARCH_CX=

# Bling (ERP)
BLING_API_KEY=
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Wix
WIX_API_KEY=
WIX_SITE_ID=

# Google Drive (conta de serviço)
GOOGLE_SERVICE_ACCOUNT_JSON=

# MCP
MCP_AUTH_TOKEN=

# Auto-enrich (job 24/7)
AUTO_ENRICH_ENABLED=true
AUTO_ENRICH_INTERVAL_MIN=
AUTO_ENRICH_BATCH_SIZE=
AUTO_ENRICH_DNA_COOLDOWN_H=
AUTO_ENRICH_IMG_COOLDOWN_H=

# Outros
PORT=
DB_PATH=
RENDER_EXTERNAL_URL=
